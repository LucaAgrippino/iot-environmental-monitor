.cproject
.project

# Build artifacts
build/
Debug/
Release/
*.o
*.elf
*.bin
*.hex
*.map
*.lst

# OS files
.DS_Store
Thumbs.db

# Visual Paradigm backups
*.vpp.bak_*
*.vpp.lck

# Temporary working files
temp/
tmp/

.claude/

# Ceedling / CMock generated
tests/build/
tests/build/test/mocks/

# Generated firmware sources
firmware/shared/firmware_version.h

# CubeIDE build outputs
firmware/**/Debug/
firmware/**/Release/
firmware/**/.settings/
firmware/**/*.launch

# Python
__pycache__/
*.pyc

# Private dev-tools — bug answer keys and interview tests must not be published
docs/dev-tools/bug-log.md
docs/dev-tools/interview-tests/

# --- Simulator (host-side LCD UI build) ---
simulator/lcd-ui/build/
simulator/lcd-ui/.cache/
simulator/lcd-ui/compile_commands.json

# CMake intermediate artefacts (if ever generated at repo root)
/build/
/CMakeCache.txt
/CMakeFiles/
/cmake_install.cmake

# Docker / WSL editor scratch
.docker/
*.swp
*.swo

# CubeIDE headless build scratch (when invoked from /tmp)
/.metadata/